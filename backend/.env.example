# MongoDB
MONGO_URL=mongodb://localhost:27017
DB_NAME=aurecasa

# Admin (obrigatório para o painel /admin funcionar)
ADMIN_EMAIL=admin@aurecasa.com.br
ADMIN_PASSWORD=

# Sessões JWT — obrigatório em produção (gere com: openssl rand -hex 32)
JWT_SECRET=

# CORS — origens do frontend, separadas por vírgula
CORS_ORIGINS=http://localhost:3000

# URL pública deste backend (usada nas URLs de uploads locais)
BACKEND_PUBLIC_URL=http://localhost:8001

# Cloudflare R2 para uploads persistentes (opcional — sem as 5 variáveis,
# uploads vão para o disco local em static/uploads)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# E-mails via Resend (opcional — sem chave, os fluxos apenas salvam no banco)
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
EMAIL_OWNER=
